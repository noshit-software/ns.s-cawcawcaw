# Required
GITHUB_WEBHOOK_SECRET=     # make something up, paste it into GitHub webhook settings
ANTHROPIC_API_KEY=         # https://console.anthropic.com
KNIGHTSROOK_MCP_URL=       # base URL of your Knightsrook MCP server

# Optional — platform credentials can also be set in the UI
# These take precedence over anything saved in ~/.cawcawcaw/credentials.json

# LinkedIn (OAuth — use the CONNECT button in the UI, these just enable it)
LINKEDIN_CLIENT_ID=        # developer.linkedin.com → your app → Auth tab
LINKEDIN_CLIENT_SECRET=    # same place
# LINKEDIN_ACCESS_TOKEN=   # auto-set by OAuth flow
# LINKEDIN_AUTHOR_URN=     # auto-set by OAuth flow

# Bluesky
# BLUESKY_HANDLE=
# BLUESKY_APP_PASSWORD=

# X/Twitter
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# Discord
# DISCORD_WEBHOOK_URL=

# Mastodon
# MASTODON_INSTANCE_URL=
# MASTODON_ACCESS_TOKEN=

# Reddit
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
# REDDIT_SUBREDDIT=

# Server
# PORT=3000
